# Reference only: Flutter does not read this file automatically.
# Copy values into --dart-define or your IDE launch configuration.

# Web OAuth client ID (also set <meta name="google-signin-client_id"> in web/index.html).
GOOGLE_WEB_CLIENT_ID=your-id.apps.googleusercontent.com

# Optional: override iOS/macOS client ID (otherwise defaults from Firebase config apply).
GOOGLE_IOS_CLIENT_ID=your-ios-id.apps.googleusercontent.com

# Example run:
# flutter run -d chrome --dart-define=GOOGLE_WEB_CLIENT_ID=$GOOGLE_WEB_CLIENT_ID
